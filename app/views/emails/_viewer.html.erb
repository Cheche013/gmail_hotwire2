<!-- app/views/emails/_viewer.html.erb -->
<%= turbo_frame_tag "viewer" do %>
  <h2 class="h4 mb-3"><%= email.object %></h2>

  <div class="mb-3">
    <%= simple_format(email.body) %>
  </div>

  <div class="d-flex gap-2">
    <%= button_to "Supprimer",
                  email_path(email),
                  method: :delete,
                  form: { data: { turbo_confirm: "Supprimer cet email ?" } },
                  class: "btn btn-outline-danger btn-sm" %>

    <button class="btn btn-outline-secondary btn-sm" disabled>
      Marquer comme non-lu
    </button>
  </div>
<% end %>
