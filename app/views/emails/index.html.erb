<%= turbo_stream_from :emails %>
<div class="container py-3">

  <div class="sticky-top bg-white border-bottom py-2" style="top:0; z-index:1020;">
    <div class="d-flex justify-content-between align-items-center">
      <h1 class="h4 mb-0">Gmail-like (Hotwire)</h1>

      <%= button_to "Recevoir un email",
                    emails_path,
                    method: :post,
                    class: "btn btn-primary btn-sm" %>
    </div>
  </div>

  
  <div class="row g-4 pt-3">
    
    <div class="col-12 col-md-4 order-1">
      <h5 class="mb-2 text-start">Liste des emails</h5>
      <%= turbo_frame_tag "emails" do %>
        <div class="list-group text-start" id="emails-list">
          <%= render @emails %>
        </div>
      <% end %>
    </div>

    
    <div class="col-12 col-md-8 order-5 order-md-2">
      <h5 class="mb-2 text-start">Email sélectionné</h5>
      <div class="border rounded p-3 bg-light text-start">
        <%= turbo_frame_tag "viewer" do %>
          <p class="text-muted mb-0">Sélectionne un email dans la colonne de gauche.</p>
        <% end %>
      </div>
    </div>
  </div>
</div>
